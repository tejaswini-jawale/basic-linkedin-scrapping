# LinkedIn Scraper Configuration
# Set your LinkedIn API key here to enable fetching:
# - Current Position
# - Current Company
# - Connections count
# - Education history
DB_HOST="localhost",
DB_USER="root",
DB_PASSWORD="",
DB_NAME=sphurtin_org_chart_db,
LINKEDIN_API_KEY=your_api_key_here

# Instructions:
# 1. Get a LinkedIn API key from https://developer.linkedin.com/
# 2. The API key is used specifically for profile data (positions, connections, education)
# 3. Company data still uses scraping methods
# 4. Make sure your API key has permissions for r_liteprofile and r_basicprofile
